{
    "batch_size": 4,
    "checkpoint_dir": "checkpoints_flowlet",
    "compile": false,
    "condition_embedding_dim": 512,
    "condition_vars": [
        "Age"
    ],
    "data_folder": "/path/to/dataset",
    "device": "cuda",
